<script async="false">

    async function handlerCounter() {
        const elemCounter = document.querySelector('.counter')
        const id = elemCounter.getAttribute('data-id')

        let response = await fetch(`http://localhost:3001/counter/${id}/incr`, {
            method: 'POST',
            headers: {
                'Origin': 'http://localhost:3000'
            }
        })
        response = await response.json()
        elemCounter.textContent = 'просмотров: ' + response.data
    }

    // обработчик на создание книги
    async function reqCreate() {
        const form = document.querySelector('.formNewBook')
        const formData = false
        let data = false
        let headers = false
        if(form.fileBook.value || form.fileCover.value) {
            formData = new FormData(form)
            headers = {
                'Content-Type': 'multipart/form-data'
            }
        } else {
            data = {}
            for (const iterator of form) {
                data[iterator.name] = iterator.value
            }
            data = JSON.stringify(data)
            headers = {
                'Content-Type': 'application/json'
            }
        }
        
        const response = await fetch("http://localhost:3000/api/books", {
            method: 'POST',
            headers: headers,
            body: formData ? formData : data
        })
        .then(async res => {

            let text = await res.json()
            if('redirect' in text) {
                location.replace(text.redirect)
                return
            } else {
                message(text)
            }
        })
        .catch(err=>console.log(err, 'error'))
    }

    // html элемент с сообщением ошибки
    function message(text) {
        const mesElem = document.querySelector('.message')
        mesElem.textContent = text.message
    }

    // клиент
    if(document.querySelector('.counter')) {
        handlerCounter()
    }

</script>