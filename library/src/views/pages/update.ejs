<%- include('../includes/layout-start')%>

<h2 class="h_update">Редактировать книгу</h2>


<form class="formUpdateBook" method="post" action="/update/<%= book.id %>" accept=".txt">
    <label class="form__label">Название книги</label>
    <textarea name="title" cols="30" rows="3"><%= book.title %></textarea>
    <label class="form__label">Описание</label>
    <textarea name="description" cols="30" rows="10"><%= book.description %></textarea>
    <label class="form__label">Автор</label>
    <textarea name="authors" cols="30" rows="3"><%= book.authors %></textarea>
    <label class="form__label">прикрепить файл книги</label>
    <input type="file" name="fileBook" multiple accept=".pdf, .txt"/>
    <label class="form__label">прикрепить обложку книги</label>
    <input type="file" name="fileCover" accept=".jpg"/>
    <button class="btnSubmit" type="submit">Сохранить</button>
</form>

<%- include('../includes/script') -%>
<%- include('../includes/layout-end')%>